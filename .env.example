# ─────────────────────────────────────────────────────────────────────────────
# Azure AI Foundry
# ─────────────────────────────────────────────────────────────────────────────

# Foundry project endpoint — auto-injected when running inside a hosted Foundry
# container. Set manually only for local development.
# Format: https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=

# Name of the GPT-4o (or other) model deployment in your Foundry project.
# Must match the deployment declared in agent.manifest.yaml.
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# ─────────────────────────────────────────────────────────────────────────────
# Azure AI Search
# ─────────────────────────────────────────────────────────────────────────────

# Full URL of your Azure AI Search service.
# Example: https://my-search.search.windows.net
AZURE_SEARCH_ENDPOINT=

# Name of the search index that holds the product catalog documents.
AZURE_SEARCH_INDEX_NAME=langchain-foundry

# API key for key-based authentication.
# Leave empty to use DefaultAzureCredential (Managed Identity / Entra ID).
AZURE_SEARCH_API_KEY=

# Name of the vector field in the index (used for semantic / hybrid search).
AZURE_SEARCH_VECTOR_FIELD=contentVector

# Name of the text content field to return in search results.
AZURE_SEARCH_CONTENT_FIELD=content

# Comma-separated list of additional fields to include in results.
# Example: id,title,category,price
AZURE_SEARCH_SELECT_FIELDS=id,title,content,category

# Maximum number of search results to return per query.
AZURE_SEARCH_TOP=5

# ─────────────────────────────────────────────────────────────────────────────
# Bing Custom Search (Grounding with Bing Custom Search)
# ─────────────────────────────────────────────────────────────────────────────

# Name of the Bing Custom Search connection in the Azure AI Foundry project.
# Create it via: az cognitiveservices account connection create ...
# Default: bing-langchain-lab-001
BING_CUSTOM_SEARCH_CONNECTION_NAME=bing-langchain-lab-001

# Full ARM resource ID of the Bing connection — required by the Azure AI Agents API.
# Format: /subscriptions/<sub>/resourceGroups/<rg>/providers/
#         Microsoft.CognitiveServices/accounts/<hub>/connections/<conn-name>
BING_CUSTOM_SEARCH_CONNECTION_ID=

# Custom Search configuration instance name (created in Azure AI Foundry portal).
BING_CUSTOM_SEARCH_CONFIG_ID=

# Maximum number of Bing search results to return per query (default: 5).
BING_CUSTOM_SEARCH_COUNT=5

# ─────────────────────────────────────────────────────────────────────────────
# Application Insights (optional — auto-injected in hosted containers)
# ─────────────────────────────────────────────────────────────────────────────
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
